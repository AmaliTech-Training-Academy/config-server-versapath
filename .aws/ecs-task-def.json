{
    "containerDefinitions": [
        {
            "name": "config-server",
            "image": "697863031884.dkr.ecr.eu-west-1.amazonaws.com/versapath/config-server:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8888,
                    "hostPort": 8888,
                    "protocol": "tcp",
                    "name": "config-server"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "SPRING_PROFILES_ACTIVE",
                    "value": "docker"
                },
                {
                    "name": "EUREKA_CLIENT_URL",
                    "value": "http://service-discovery:8761/eureka"
                },
                {
                    "name": "SERVER_PORT",
                    "value": "8888"
                },
                {
                    "name": "CONFIG_REPO_GIT_URL",
                    "value": "https://github.com/AmaliTech-Training-Academy/config-repository-versapath"
                },
                {
                    "name": "CONFIG_SERVER_GIT_DEFAULT_LABEL",
                    "value": "dev"
                },
                {
                    "name": "CLONE_ON_START",
                    "value": "true"
                },
                {
                    "name": "SPRING_APPLICATION_NAME",
                    "value": "config-server"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/versapath/config-server",
                    "awslogs-region": "eu-west-1",
                    "awslogs-stream-prefix": "config-server"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "wget --no-verbose --tries=1 --spider http://localhost:8888/actuator/health || curl -f http://localhost:8888/actuator/health || exit 1"
                ],
                "interval": 60,
                "timeout": 10,
                "retries": 3,
                "startPeriod": 120
            },
            "systemControls": []
        }
    ],
    "family": "versapath-config-server",
    "taskRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-role",
    "executionRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-execution-role",
    "networkMode": "awsvpc",
    "volumes": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024"
}
